<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="RRRbot">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import RRRbot urdf file -->
    <xacro:include filename="$(find rrrbot_moveit_demo)/urdf/rrrbot.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="RRRbot.ros2_control.xacro" />


    <xacro:RRRbot_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
