<?xml version="1.0"?>
<!--
  Gazebo Classic version of the sensor robot.
  Plugins publish directly to ROS 2 topics — no ros_gz_bridge needed.
-->
<robot name="sensor_robot_classic">

  <!-- ───── Links ───── -->

  <link name="base_link">
    <visual>
      <geometry><box size="0.3 0.2 0.1"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.3 0.2 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.008333" ixy="0" ixz="0"
                               iyy="0.016667" iyz="0"
                                              izz="0.021667"/>
    </inertial>
  </link>

  <link name="left_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.06"/></geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.06"/></geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.000554" ixy="0" ixz="0"
                               iyy="0.000900" iyz="0"
                                              izz="0.000554"/>
    </inertial>
  </link>

  <link name="right_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.06"/></geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.06"/></geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.000554" ixy="0" ixz="0"
                               iyy="0.000900" iyz="0"
                                              izz="0.000554"/>
    </inertial>
  </link>

  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000036" ixy="0" ixz="0"
                               iyy="0.000036" iyz="0"
                                              izz="0.000036"/>
    </inertial>
  </link>

  <!-- LiDAR mount -->
  <link name="laser_frame">
    <visual>
      <geometry><cylinder length="0.04" radius="0.05"/></geometry>
      <material name="red"><color rgba="0.8 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.04" radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000076" ixy="0" ixz="0"
                               iyy="0.000076" iyz="0"
                                              izz="0.000125"/>
    </inertial>
  </link>

  <!-- Depth camera mount -->
  <link name="depth_frame">
    <visual>
      <geometry><box size="0.04 0.09 0.03"/></geometry>
      <material name="green"><color rgba="0 0.6 0 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.04 0.09 0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.000010" ixy="0" ixz="0"
                               iyy="0.000010" iyz="0"
                                              izz="0.000010"/>
    </inertial>
  </link>

  <!-- RGB camera mount -->
  <link name="camera_frame">
    <visual>
      <geometry><box size="0.04 0.06 0.04"/></geometry>
      <material name="blue"><color rgba="0 0 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.04 0.06 0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.000010" ixy="0" ixz="0"
                               iyy="0.000010" iyz="0"
                                              izz="0.000010"/>
    </inertial>
  </link>

  <!-- ───── Joints ───── -->

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <origin xyz="0.05 0.125 -0.05" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  effort="10" velocity="10"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <origin xyz="0.05 -0.125 -0.05" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  effort="10" velocity="10"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_wheel"/>
    <origin xyz="-0.1 0 -0.08" rpy="0 0 0"/>
  </joint>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser_frame"/>
    <origin xyz="0.0 0 0.075" rpy="0 0 0"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_frame"/>
    <origin xyz="0.16 0 0.06" rpy="0 0 0"/>
  </joint>

  <joint name="depth_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="depth_frame"/>
    <origin xyz="0.16 0 0.11" rpy="0 0 0"/>
  </joint>

  <!-- ───── Gazebo Classic material colours ───── -->

  <gazebo reference="base_link">
    <material>Gazebo/Gray</material>
  </gazebo>
  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="caster_wheel">
    <material>Gazebo/Gray</material>
    <mu1>0</mu1>
    <mu2>0</mu2>
  </gazebo>
  <gazebo reference="laser_frame">
    <material>Gazebo/Red</material>
  </gazebo>
  <gazebo reference="camera_frame">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="depth_frame">
    <material>Gazebo/Green</material>
  </gazebo>

  <!-- High friction on drive wheels -->
  <gazebo reference="left_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="right_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <!-- ───── Diff drive plugin (Gazebo Classic) ───── -->

  <gazebo>
    <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.25</wheel_separation>
      <wheel_diameter>0.12</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- ───── Joint state publisher (Gazebo Classic) ───── -->
  <!-- Required so robot_state_publisher can compute wheel transforms for RViz -->

  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher"
            filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>10</update_rate>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- ───── LiDAR sensor (Gazebo Classic) ───── -->

  <gazebo reference="laser_frame">
    <sensor type="ray" name="laser">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>36</samples>
            <resolution>1</resolution>
            <min_angle>-1.5708</min_angle>
            <max_angle>1.5708</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ───── 3D LiDAR sensor — VLP-16 equivalent (Gazebo Classic) ───── -->

  <!-- <gazebo reference="laser_frame">
    <sensor type="ray" name="lidar_3d">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1800</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.26180</min_angle>
            <max_angle>0.26180</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.5</min>
          <max>100.0</max>
          <resolution>0.03</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.008</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_3d_lidar" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=points</remapping>
        </ros>
        <output_type>sensor_msgs/PointCloud2</output_type>
        <frame_name>laser_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo> -->

  <!-- ───── RGB camera sensor (Gazebo Classic) ───── -->

  <gazebo reference="camera_frame">
    <sensor type="camera" name="rgb_camera">
      <update_rate>30.0</update_rate>
      <visualize>true</visualize>
      <camera name="rgb">
        <horizontal_fov>1.0472</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin name="gazebo_ros_camera" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>image_raw:=camera/image_raw</remapping>
          <remapping>camera_info:=camera/camera_info</remapping>
        </ros>
        <camera_name>camera</camera_name>
        <frame_name>camera_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ───── Depth camera (Gazebo Classic) ───── -->
  <!--
    NOT SUPPORTED: libgazebo_ros_openni_kinect.so and libgazebo_ros_depth_camera.so
    were never ported to ROS 2. Gazebo Classic has no depth camera plugin in ROS 2 Humble.
  -->

</robot>
